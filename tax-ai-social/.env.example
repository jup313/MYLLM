# ============================================================
# Tax AI Social Media Engine — Environment Config
# Copy this file to .env and fill in your values
# ============================================================

# Meta / Facebook Page
PAGE_ID=your_facebook_page_id
PAGE_ACCESS_TOKEN=your_long_lived_page_access_token

# Instagram Business Account ID (linked to Facebook Page)
INSTAGRAM_ACCOUNT_ID=your_instagram_business_account_id

# Ollama Settings
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=mistral:7b

# App Settings
FLASK_PORT=5055
FLASK_SECRET_KEY=change_this_to_random_string

# Schedule — time to generate posts daily (24-hour format)
SCHEDULE_HOUR=6
SCHEDULE_MINUTE=0

# Auto-post after approval? (true = posts immediately on approve click)
AUTO_POST_ON_APPROVE=true

# Firm Info (used in prompts)
FIRM_NAME=Your Firm Name
FIRM_LOCATION=City, State
FIRM_SERVICES=tax preparation, tax resolution, bookkeeping
FIRM_AUDIENCE=small business owners, self-employed, individuals

# Business Contact Info (auto-appended to every post)
FIRM_PHONE=(555) 555-0000
FIRM_EMAIL=info@yourfirm.com
FIRM_WHATSAPP=(555) 555-0000
FIRM_WEBSITE=www.yourfirm.com
FIRM_ADDRESS=City, State
FIRM_FAX=
FIRM_INSTAGRAM=@yourhandle
FIRM_FACEBOOK=Your Business Name

# Include contact block at end of posts? (true/false)
INCLUDE_CONTACT_BLOCK=true
